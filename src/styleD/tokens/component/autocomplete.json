				},
				"borderColor": {
					"$type": "color",
					"$value": "{semantic.colors.border.stronger}"
				},
				"paddingY": {
					"$type": "dimension",
					"$value": "8px"
				},
				"paddingX": {
					"$type": "dimension",
					"$value": "0px"
				},
				"backgroundColor": {
					"$type": "color",
					"$value": "{semantic.colors.fill.weak}"
				},
				"item": {
					"paddingY": {
						"$type": "dimension",
						"$value": "8px"
					},
					"paddingX": {
						"$type": "dimension",
						"$value": "12px"
					},
					"backgroundHoverColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.neutralWeak}"
					},
					"backgroundFocusedColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.neutralWeak}"
					},
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.strong}"
					},
					"colorHover": {
						"$type": "color",
						"$value": "{semantic.colors.text.strong}"
					},
					"colorFocused": {
						"$type": "color",
						"$value": "{semantic.colors.text.strong}"
					}
				}
			}
		}
