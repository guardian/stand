{
	"component": {
		"autocomplete": {
			"input": {
				"color": {
					"$type": "color",
					"$value": "{semantic.colors.text.strong}"
				},
				"backgroundColor": {
					"$type": "color",
					"$value": "{semantic.colors.fill.weak}"
				},
				"borderWidth": {
					"$type": "dimension",
					"$value": "{semantic.sizing.border.default}"
				},
				"borderStyle": {
					"$type": "strokeStyle",
					"$value": "solid"
				},
				"borderColor": {
					"$type": "color",
					"$value": "{semantic.colors.border.stronger}"
				},
				"padding": {
					"$type": "dimension",
					"$value": "{base.spacing.12Rem}"
				},
				"borderRadius": {
					"$type": "dimension",
					"$value": "{base.radius.corner4Rem}"
				},
				"hover": {
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weakHover}"
					}
				},
				"focused": {
					"outline": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.focused}",
							"width": "{semantic.sizing.border.md}",
							"style": "solid"
						}
					},
					"outlineOffset": {
						"$type": "dimension",
						"$value": "{base.spacing.2Rem}"
					}
				},
				"disabled": {
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weak}"
					},
					"cursor": {
						"$type": "string",
						"$value": "not-allowed"
					},
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.disabled}"
					},
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.disabled}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					}
				}
			},
			"icon": {
				"size": {
					"$type": "dimension",
					"$value": "20px"
				},
				"paddingX": {
					"$type": "dimension",
					"$value": "4px"
				},
				"color": {
					"$type": "color",
