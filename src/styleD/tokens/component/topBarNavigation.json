{
	"component": {
		"TopBar": {
			"Navigation": {
				"shared": {
					"display": {
						"$type": "string",
						"$value": "inline-flex"
					},
					"position": {
						"$type": "string",
						"$value": "relative"
					},
					"alignItems": {
						"$type": "string",
						"$value": "center"
					},
					"cursor": {
						"$type": "string",
						"$value": "pointer"
					},
					"textDecoration": {
						"$type": "string",
						"$value": "none"
					},
					"height": {
						"$type": "dimension",
						"$value": "100%"
					},
					"disabled": {
						"cursor": {
							"$type": "string",
							"$value": "not-allowed"
						},
						"color": {
							"$type": "color",
							"$value": "{semantic.colors.text.disabled}"
						}
					},
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "0"
						},
						"right": {
							"$type": "dimension",
							"$value": "{base.spacing.16Rem}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "0"
						},
						"left": {
							"$type": "dimension",
							"$value": "{base.spacing.16Rem}"
						}
					},
					"focusVisible": {
						"outline": {
							"$type": "border",
							"$value": {
								"color": "{semantic.colors.border.focused}",
								"width": "{semantic.sizing.border.md}",
								"style": "solid"
							}
						},
						"outlineOffset": {
							"$type": "dimension",
							"$value": "-{semantic.sizing.border.default}"
						}
					},
					"borderTop": {
						"$type": "border",
						"$value": {
							"color": "transparent",
							"width": "{semantic.sizing.border.extraWide}",
							"style": "solid"
						}
					},
					"divider": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.weak}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					},
					"_menuOpen": {
						"width": { "$type": "dimension", "$value": "100%" },
						"height": { "$type": "dimension", "$value": "64px" },
						"selected": {
							"backgroundColor": {
								"$type": "color",
								"$value": "{semantic.colors.bg.raisedLevel2}"
							}
						}
					}
				},
				"text": {
					"margin": {
						"left": { "$type": "dimension", "$value": "{base.spacing.6Rem}" }
					}
				},
				"menuIndicator": {
					"margin": {
						"top": {
							"$type": "dimension",
							"$value": "{base.spacing.6Rem}"
						},
						"left": {
							"$type": "dimension",
							"$value": "{base.spacing.2Rem}"
						}
					}
				},
				"selected": {
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.strong}"
					},
					"borderBottom": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.selected}",
							"width": "{semantic.sizing.border.extraWide}",
							"style": "solid"
						}
					}
				},
				"unselected": {
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.weak}"
					},
					"borderBottom": {
						"$type": "border",
						"$value": {
							"color": "transparent",
							"width": "{semantic.sizing.border.extraWide}",
							"style": "solid"
						}
					}
				},
				"md": {
					"typography": {
						"font": {
							"$type": "typography",
							"$value": "{semantic.typography.headingMd.font}"
						},
						"letterSpacing": {
							"$type": "dimension",
							"$value": "{semantic.typography.headingMd.letterSpacing}"
						},
						"fontWidth": {
							"$type": "number",
							"$value": "{semantic.typography.headingMd.fontWidth}"
						}
					}
				},
				"sm": {
					"typography": {
						"font": {
							"$type": "typography",
							"$value": "{semantic.typography.headingSm.font}"
						},
						"letterSpacing": {
							"$type": "dimension",
							"$value": "{semantic.typography.headingSm.letterSpacing}"
						},
						"fontWidth": {
							"$type": "number",
							"$value": "{semantic.typography.headingSm.fontWidth}"
						}
					}
				}
			}
		}
	}
}
