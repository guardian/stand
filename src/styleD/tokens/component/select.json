{
	"component": {
		"select": {
			"shared": {
				"width": {
					"$type": "dimension",
					"$value": "100%"
				},
				"hover": {
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weakHover}"
					},
					"outline": {
						"$description": "Override outline focus styles on hover",
						"$type": "border",
						"$value": "none"
					}
				},
				"pressed": {
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weakPressed}"
					}
				},
				"button": {
					"display": {
						"$type": "string",
						"$value": "flex"
					},
					"justifyContent": {
						"$type": "string",
						"$value": "space-between"
					},
					"alignItems": {
						"$type": "string",
						"$value": "center"
					},
					"marginTop": {
						"$type": "dimension",
						"$value": "{base.spacing.4Rem}"
					},
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weak}"
					},
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.stronger}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					},
					"borderRadius": {
						"$type": "dimension",
						"$value": "{base.radius.corner4Rem}"
					},
					"height": {
						"$type": "dimension",
						"$value": "{base.sizing.size40Rem}"
					},
					"paddingLeft": {
						"$type": "dimension",
						"$value": "{base.spacing.12Rem}"
					},
					"paddingRight": {
						"$type": "dimension",
						"$value": "{base.spacing.4Rem}"
					},
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.weak}"
					},
					"typography": {
						"font": {
							"$type": "typography",
							"$value": "{semantic.typography.bodyMd.font}"
						},
						"letterSpacing": {
							"$type": "dimension",
							"$value": "{semantic.typography.bodyMd.letterSpacing}"
						},
						"fontWidth": {
							"$type": "number",
							"$value": "{semantic.typography.bodyMd.fontWidth}"
						}
					},
					"focused": {
						"outline": {
							"$type": "border",
							"$value": {
								"color": "{semantic.colors.border.focused}",
								"width": "{semantic.sizing.border.md}",
								"style": "solid"
							}
						},
						"outlineOffset": {
							"$type": "dimension",
							"$value": "{base.spacing.2Rem}"
						}
					},
					"disabled": {
						"backgroundColor": {
							"$type": "color",
							"$value": "{semantic.colors.fill.weak}"
						},
						"cursor": {
							"$type": "string",
							"$value": "not-allowed"
						},
						"color": {
							"$type": "color",
							"$value": "{semantic.colors.text.disabled}"
						},
						"border": {
							"$type": "border",
							"$value": {
								"color": "{semantic.colors.border.disabled}",
								"width": "{semantic.sizing.border.default}",
								"style": "solid"
							}
						}
					},
					"error": {
						"border": {
							"$type": "border",
							"$value": {
								"color": "{semantic.colors.border.error}",
								"width": "{semantic.sizing.border.default}",
								"style": "solid"
							}
						}
					}
				},
				"option": {
					"paddingLeft": {
						"$type": "dimension",
						"$value": "{base.spacing.16Rem}"
					},
					"paddingRight": {
						"$type": "dimension",
						"$value": "{base.spacing.16Rem}"
					},
					"paddingTop": {
						"$type": "dimension",
						"$value": "{base.spacing.12Rem}"
					},
					"paddingBottom": {
						"$type": "dimension",
						"$value": "{base.spacing.12Rem}"
					},
					"focused": {
						"outline": {
							"$type": "border",
							"$value": {
								"color": "{semantic.colors.border.focused}",
								"width": "{semantic.sizing.border.md}",
								"style": "solid"
							}
						},
						"outlineOffset": {
							"$type": "dimension",
							"$value": "0"
						},
						"backgroundColor": {
							"$type": "color",
							"$value": "inherit"
						}
					}
				},
				"listBox": {
					"typography": {
						"font": {
							"$type": "typography",
							"$value": "{semantic.typography.bodyMd.font}"
						},
						"letterSpacing": {
							"$type": "dimension",
							"$value": "{semantic.typography.bodyMd.letterSpacing}"
						},
						"fontWidth": {
							"$type": "number",
							"$value": "{semantic.typography.bodyMd.fontWidth}"
						}
					},
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.weak}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					},
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weak}"
					},
					"shadow": {
						"$type": "shadow",
						"$value": "{semantic.shadow.raised}"
					}
				}
			}
		}
	}
}
