{
	"component": {
		"TopBar": {
			"Item": {
				"display": {
					"$type": "string",
					"$value": "flex"
				},
				"alignItems": {
					"$type": "string",
					"$value": "center"
				},
				"height": {
					"$type": "dimension",
					"$value": "100%"
				},
				"sm": {
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "0"
						},
						"right": {
							"$type": "dimension",
							"$value": "{base.spacing.12Rem}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "0"
						},
						"left": {
							"$type": "dimension",
							"$value": "{base.spacing.12Rem}"
						}
					}
				},
				"md": {
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "0"
						},
						"right": {
							"$type": "dimension",
							"$value": "{base.spacing.16Rem}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "0"
						},
						"left": {
							"$type": "dimension",
							"$value": "{base.spacing.16Rem}"
						}
					}
				},
				"lg": {
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "0"
						},
						"right": {
							"$type": "dimension",
							"$value": "{base.spacing.24Rem}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "0"
						},
						"left": {
							"$type": "dimension",
							"$value": "{base.spacing.24Rem}"
						}
					}
				},
				"border": {
					"$type": "border",
					"$value": {
						"color": "{semantic.colors.border.weak}",
						"width": "{semantic.sizing.border.default}",
						"style": "solid"
					}
				}
			}
		}
	}
}
