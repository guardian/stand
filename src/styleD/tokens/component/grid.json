{
	"component": {
		"grid": {
			"shared": {
				"display": {
					"$type": "string",
					"$value": "flex"
				},
				"width": {
					"$type": "string",
					"$value": "100%"
				},
				"direction": {
					"$type": "string",
					"$value": "row"
				},
				"wrap": {
					"$type": "string",
					"$value": "wrap"
				},
				"justifyContent": {
					"$type": "string",
					"$value": "flex-start"
				},
				"alignItems": {
					"$type": "string",
					"$value": "stretch"
				}
			},
			"sm": {
				"columns": {
					"$type": "number",
					"$value": "{semantic.grid.columns.sm}"
				},
				"gap": {
					"$type": "dimension",
					"$value": "{semantic.grid.gutter.sm-px}"
				},
				"padding": {
					"$type": "dimension",
					"$value": "{semantic.grid.margin.sm-px}"
				}
			},
			"md": {
				"columns": {
					"$type": "number",
					"$value": "{semantic.grid.columns.md}"
				},
				"gap": {
					"$type": "dimension",
					"$value": "{semantic.grid.gutter.md-px}"
				},
				"padding": {
					"$type": "dimension",
					"$value": "{semantic.grid.margin.md-px}"
				}
			},
			"lg": {
				"columns": {
					"$type": "number",
					"$value": "{semantic.grid.columns.lg}"
				},
				"gap": {
					"$type": "dimension",
					"$value": "{semantic.grid.gutter.lg-px}"
				},
				"padding": {
					"$type": "dimension",
					"$value": "{semantic.grid.margin.lg-px}"
				}
			}
		}
	}
}
