{
	"component": {
		"menu": {
			"menu": {
				"shared": {
					"display": {
						"$type": "string",
						"$value": "flex"
					},
					"flexDirection": {
						"$type": "string",
						"$value": "column"
					},
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.bg.base}"
					},
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.weak}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					}
				}
			},
			"menuSection": {
				"header": {
					"shared": {
						"display": {
							"$type": "string",
							"$value": "flex"
						},
						"alignItems": {
							"$type": "string",
							"$value": "center"
						},
						"padding": {
							"top": {
								"$type": "dimension",
								"$value": "0"
							},
							"right": {
								"$type": "dimension",
								"$value": "{base.spacing.8Rem}"
							},
							"bottom": {
								"$type": "dimension",
								"$value": "0"
							},
							"left": {
								"$type": "dimension",
								"$value": "{base.spacing.8Rem}"
							}
						},
						"backgroundColor": {
							"$type": "color",
							"$value": "{semantic.colors.bg.raisedLevel2}"
						},
						"color": {
							"$type": "color",
							"$value": "{semantic.colors.text.strong}"
						}
					},
					"sm": {
						"height": {
							"$type": "dimension",
							"$value": "{semantic.sizing.height.xs}"
						},
						"typography": {
							"font": {
								"$type": "typography",
								"$value": "{semantic.typography.interactiveSm.font}"
							},
							"letterSpacing": {
								"$type": "dimension",
								"$value": "{semantic.typography.interactiveSm.letterSpacing}"
							},
							"fontWidth": {
								"$type": "number",
								"$value": "{semantic.typography.interactiveSm.fontWidth}"
							}
						}
					},
					"md": {
						"height": {
							"$type": "dimension",
							"$value": "{semantic.sizing.height.sm}"
						},
						"typography": {
							"font": {
								"$type": "typography",
								"$value": "{semantic.typography.interactiveMd.font}"
							},
							"letterSpacing": {
								"$type": "dimension",
								"$value": "{semantic.typography.interactiveMd.letterSpacing}"
							},
							"fontWidth": {
								"$type": "number",
								"$value": "{semantic.typography.interactiveMd.fontWidth}"
							}
						}
					}
				}
			},
			"menuItem": {
				"shared": {
					"display": {
						"$type": "string",
						"$value": "grid"
					},
					"gridTemplateAreas": {
						"$type": "string",
						"$value": "'{component.menu.menuItem.shared.icon.gridArea} {component.menu.menuItem.shared.label.gridArea} {component.menu.menuItem.shared.aside.gridArea}'"
					},
					"gridTemplateAreasWithDescription": {
						"$type": "string",
						"$value": "'{component.menu.menuItem.shared.icon.gridArea} {component.menu.menuItem.shared.label.gridArea} {component.menu.menuItem.shared.aside.gridArea}' '. {component.menu.menuItem.shared.description.gridArea} .'"
					},
					"gridTemplateColumns": {
						"$type": "string",
						"$value": "auto 6fr 1fr"
					},
					"gap": {
						"$type": "dimension",
						"$value": "{base.spacing.4Rem}"
					},
					"alignItems": {
						"$type": "string",
						"$value": "center"
					},
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "{base.spacing.12Rem}"
						},
						"right": {
							"$type": "dimension",
							"$value": "{base.spacing.16Rem}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "{base.spacing.12Rem}"
						},
						"left": {
							"$type": "dimension",
							"$value": "{base.spacing.16Rem}"
						}
					},
					"borderBottom": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.weak}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					},
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weak}"
					},
					"icon": {
						"gridArea": {
							"$type": "string",
							"$value": "icon"
						},
						"alignSelf": {
							"$type": "string",
							"$value": "start"
						},
						"color": {
							"$type": "color",
							"$value": "{semantic.colors.text.weak}"
						}
					},
					"label": {
						"gridArea": {
							"$type": "string",
							"$value": "label"
						},
						"color": {
							"$type": "color",
							"$value": "{semantic.colors.text.strong}"
						},
						"typography": {
							"font": {
								"$type": "typography",
								"$value": "{semantic.typography.bodyMd.font}"
							},
							"letterSpacing": {
								"$type": "dimension",
								"$value": "{semantic.typography.bodyMd.letterSpacing}"
							},
							"fontWidth": {
								"$type": "number",
								"$value": "{semantic.typography.bodyMd.fontWidth}"
							}
						}
					},
					"description": {
						"gridArea": {
							"$type": "string",
							"$value": "description"
						},
						"color": {
							"$type": "color",
							"$value": "{semantic.colors.text.weak}"
						},
						"typography": {
							"font": {
								"$type": "typography",
								"$value": "{semantic.typography.bodySm.font}"
							},
							"letterSpacing": {
								"$type": "dimension",
								"$value": "{semantic.typography.bodySm.letterSpacing}"
							},
							"fontWidth": {
								"$type": "number",
								"$value": "{semantic.typography.bodySm.fontWidth}"
							}
						}
					},
					"aside": {
						"gridArea": {
							"$type": "string",
							"$value": "aside"
						},
						"justifySelf": {
							"$type": "string",
							"$value": "end"
						},
						"alignSelf": {
							"$type": "string",
							"$value": "start"
						},
						"color": {
							"$type": "color",
							"$value": "{semantic.colors.text.strong}"
						},
						"typography": {
							"font": {
								"$type": "typography",
								"$value": "{semantic.typography.bodyMd.font}"
							},
							"letterSpacing": {
								"$type": "dimension",
								"$value": "{semantic.typography.bodyMd.letterSpacing}"
							},
							"fontWidth": {
								"$type": "number",
								"$value": "{semantic.typography.bodyMd.fontWidth}"
							}
						}
					},
					"lastChild": {
						"borderBottom": {
							"$type": "border",
							"$value": "none"
						}
					},
					"hover": {
						"backgroundColor": {
							"$type": "color",
							"$value": "{semantic.colors.fill.weakHover}"
						},
						"outline": {
							"$description": "Override outline focus styles on hover",
							"$type": "border",
							"$value": "none"
						}
					},
					"focusVisible": {
						"outline": {
							"$type": "border",
							"$value": {
								"color": "{semantic.colors.border.focused}",
								"width": "{semantic.sizing.border.md}",
								"style": "solid"
							}
						},
						"outlineOffset": {
							"$type": "dimension",
							"$value": "-{semantic.sizing.border.md}"
						}
					},
					"pressed": {
						"backgroundColor": {
							"$type": "color",
							"$value": "{semantic.colors.fill.weakPressed}"
						}
					}
				},
				"sm": {
					"icon": {
						"size": {
							"$type": "dimension",
							"$value": "{component.icon.sm.size}"
						},
						"lineHeight": {
							"$type": "dimension",
							"$value": "{base.typography.lineHeight.normal}"
						}
					}
				},
				"md": {
					"icon": {
						"size": {
							"$type": "dimension",
							"$value": "{component.icon.md.size}"
						},
						"lineHeight": {
							"$type": "dimension",
							"$value": "{base.typography.lineHeight.normal}"
						}
					}
				}
			},
			"menuSeparator": {
				"shared": {
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.border.weaker}"
					},
					"height": {
						"$type": "dimension",
						"$value": "{base.sizing.size8Rem}"
					},
					"width": {
						"$type": "dimension",
						"$value": "100%"
					}
				}
			},
			"menuPopover": {
				"shared": {
					"overflow": {
						"$type": "string",
						"$value": "auto"
					},
					"shadow": {
						"$type": "shadow",
						"$value": "{semantic.shadow.raised}"
					}
				},
				"sm": {
					"maxWidth": {
						"$type": "dimension",
						"$value": "200px"
					},
					"width": {
						"$type": "dimension",
						"$value": "100%"
					}
				},
				"md": {
					"maxWidth": {
						"$type": "dimension",
						"$value": "320px"
					},
					"width": {
						"$type": "dimension",
						"$value": "100%"
					}
				}
			}
		}
	}
}
