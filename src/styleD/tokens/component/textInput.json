{
	"component": {
		"textInput": {
			"shared": {
				"color": {
					"$type": "color",
					"$value": "{semantic.colors.text.strong}"
				},
				"cursor": {
					"$type": "string",
					"$value": "text"
				},
				"padding": {
					"top": {
						"$type": "dimension",
						"$value": "0"
					},
					"right": {
						"$type": "dimension",
						"$value": "{base.spacing.12-rem}"
					},
					"bottom": {
						"$type": "dimension",
						"$value": "0"
					},
					"left": {
						"$type": "dimension",
						"$value": "{base.spacing.12-rem}"
					}
				},
				"margin-top": {
					"$description": "spacing between the input itself and the previous element (label or description) minus the flex gap (default 4px), e.g. if the spacing between label and input should be 12px, then margin-top should be 8px",
					"$type": "dimension",
					"$value": "{base.spacing.8-rem}"
				},
				"border-radius": {
					"$type": "dimension",
					"$value": "{base.radius.corner-4-rem}"
				},
				"border": {
					"$type": "border",
					"$value": {
						"color": "{semantic.colors.border.stronger}",
						"width": "{semantic.sizing.border.default}",
						"style": "solid"
					}
				},
				"background-color": {
					"$type": "color",
					"$value": "{semantic.colors.fill.weak}"
				},
				"disabled": {
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.weak}"
					},
					"cursor": {
						"$type": "string",
						"$value": "not-allowed"
					},
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.disabled}"
					},
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.disabled}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					}
				},
				"error": {
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.error}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					}
				}
			},
			"sm": {
				"height": {
					"$type": "dimension",
					"$value": "{semantic.sizing.height.sm}"
				},
				"typography": {
					"font": {
						"$type": "typography",
						"$value": "{semantic.typography.body-sm.font}"
					},
					"letterSpacing": {
						"$type": "typography",
						"$value": "{semantic.typography.body-sm.letterSpacing}"
					},
					"fontWidth": {
						"$type": "typography",
						"$value": "{semantic.typography.body-sm.fontWidth}"
					}
				}
			},
			"md": {
				"height": {
					"$type": "dimension",
					"$value": "{semantic.sizing.height.md}"
				},
				"typography": {
					"font": {
						"$type": "typography",
						"$value": "{semantic.typography.body-md.font}"
					},
					"letterSpacing": {
						"$type": "typography",
						"$value": "{semantic.typography.body-md.letterSpacing}"
					},
					"fontWidth": {
						"$type": "typography",
						"$value": "{semantic.typography.body-md.fontWidth}"
					}
				}
			}
		}
	}
}
