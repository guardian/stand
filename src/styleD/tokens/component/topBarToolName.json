{
	"component": {
		"topBar": {
			"toolName": {
				"display": {
					"$type": "string",
					"$value": "flex"
				},
				"color": {
					"$type": "color",
					"$value": "{semantic.colors.text.strong}"
				},
				"alignItems": {
					"$type": "string",
					"$value": "center"
				},
				"gap": {
					"$type": "dimension",
					"$value": "{base.spacing.8Rem}"
				},
				"typography": {
					"font": {
						"$type": "typography",
						"$value": "{semantic.typography.titleMd.font}"
					},
					"letterSpacing": {
						"$type": "dimension",
						"$value": "{semantic.typography.titleMd.letterSpacing}"
					},
					"fontWidth": {
						"$type": "number",
						"$value": "{semantic.typography.titleMd.fontWidth}"
					}
				},
				"divider": {
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.weak}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					},
					"height": {
						"$type": "dimension",
						"$value": "{base.sizing.size32Rem}"
					}
				},
				"subsection": {
					"gap": {
						"$type": "dimension",
						"$value": "{base.spacing.2Rem}"
					},
					"typography": {
						"font": {
							"$type": "typography",
							"$value": "{semantic.typography.headingCompactMd.font}"
						},
						"letterSpacing": {
							"$type": "dimension",
							"$value": "{semantic.typography.headingCompactMd.letterSpacing}"
						},
						"fontWidth": {
							"$type": "number",
							"$value": "{semantic.typography.headingCompactMd.fontWidth}"
						}
					}
				},
				"link": {
					"textDecoration": {
						"$type": "string",
						"$value": "none"
					},
					"color": {
						"$type": "color",
						"$value": "unset"
					},
					"position": {
						"$type": "string",
						"$value": "relative"
					},
					"width": {
						"$type": "dimension",
						"$value": "100%"
					},
					"height": {
						"$type": "dimension",
						"$value": "100%"
					}
				},
				"hoverLink": {
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.strongerInverse}"
					},
					"paddingLeft": {
						"$type": "dimension",
						"$value": "{base.spacing.20Rem}"
					},
					"paddingRight": {
						"$type": "dimension",
						"$value": "{base.spacing.20Rem}"
					},
					"backgroundColor": {
						"$type": "color",
						"$value": "{semantic.colors.fill.accentStrongHover}"
					},
					"opacity": {
						"$type": "number",
						"$value": "0"
					},
					"typography": {
						"font": {
							"$type": "typography",
							"$value": "{semantic.typography.bodyBoldSm.font}"
						},
						"letterSpacing": {
							"$type": "dimension",
							"$value": "{semantic.typography.bodyBoldSm.letterSpacing}"
						},
						"fontWidth": {
							"$type": "number",
							"$value": "{semantic.typography.bodyBoldSm.fontWidth}"
						}
					},
					"position": {
						"$type": "string",
						"$value": "absolute"
					},
					"width": {
						"$type": "dimension",
						"$value": "100%"
					},
					"height": {
						"$type": "dimension",
						"$value": "100%"
					},
					"hover": {
						"opacity": {
							"$type": "number",
							"$value": "1"
						}
					},
					"pressed": {
						"backgroundColor": {
							"$type": "color",
							"$value": "{semantic.colors.fill.accentStrongPressed}"
						}
					},
					"focused": {
						"outline": {
							"$type": "border",
							"$value": {
								"color": "{semantic.colors.border.focused}",
								"width": "{semantic.sizing.border.md}",
								"style": "solid"
							}
						},
						"outlineOffset": {
							"$type": "dimension",
							"$value": "-{base.spacing.2Rem}"
						}
					},
					"collapsed": {
						"paddingLeft": {
							"$type": "dimension",
							"$value": "{base.spacing.4Rem}"
						},
						"paddingRight": {
							"$type": "dimension",
							"$value": "{base.spacing.4Rem}"
						},
						"justifyContent": {
							"$type": "string",
							"$value": "center"
						}
					}
				}
			}
		}
	}
}
