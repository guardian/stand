{
	"component": {
		"layout": {
			"layout": {
				"shared": {
					"display": {
						"$type": "string",
						"$value": "grid"
					},
					"minHeight": {
						"$type": "dimension",
						"$value": "100svh"
					},
					"width": {
						"$type": "dimension",
						"$value": "100%"
					}
				},
				"sm": {
					"gridTemplateAreas": {
						"$type": "string",
						"$value": "'alertbanner'\n'topbar'\n'sidebar'\n'main'"
					},
					"gridTemplateColumns": {
						"$type": "string",
						"$value": "1fr"
					},
					"gridTemplateRows": {
						"$type": "string",
						"$value": "min-content min-content min-content 1fr"
					}
				},
				"md": {
					"gridTemplateAreas": {
						"$type": "string",
						"$value": "'alertbanner alertbanner'\n'topbar topbar'\n'sidebar main'"
					},
					"gridTemplateColumns": {
						"$type": "string",
						"$value": "min-content 1fr"
					},
					"gridTemplateRows": {
						"$type": "string",
						"$value": "min-content min-content 1fr"
					}
				},
				"lg": {
					"gridTemplateAreas": {
						"$type": "string",
						"$value": "'alertbanner alertbanner'\n'topbar topbar'\n'sidebar main'"
					},
					"gridTemplateColumns": {
						"$type": "string",
						"$value": "min-content 1fr"
					},
					"gridTemplateRows": {
						"$type": "string",
						"$value": "min-content min-content 1fr"
					}
				}
			},
			"sidebar": {
				"sm": {
					"hidden": {
						"display": {
							"$type": "string",
							"$value": "none"
						}
					},
					"aboveGrid": {
						"display": {
							"$type": "string",
							"$value": "block"
						}
					}
				},
				"md": {
					"display": {
						"$type": "string",
						"$value": "block"
					},
					"width": {
						"$type": "dimension",
						"$value": "{semantic.sizing.sidebar.mdPx}"
					}
				},
				"lg": {
					"width": {
						"$type": "dimension",
						"$value": "{semantic.sizing.sidebar.lgPx}"
					}
				}
			},
			"main": {
				"maxWidth": {
					"$type": "dimension",
					"$value": "{semantic.sizing.layout.maxWidthPx}"
				},
				"marginLeft": {
					"$type": "string",
					"$value": "auto"
				},
				"marginRight": {
					"$type": "string",
					"$value": "auto"
				},
				"sm": {
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "{semantic.grid.margin.topSmPx}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "{semantic.grid.margin.bottomSmPx}"
						}
					}
				},
				"md": {
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "{semantic.grid.margin.topMdPx}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "{semantic.grid.margin.bottomMdPx}"
						}
					}
				},
				"lg": {
					"padding": {
						"top": {
							"$type": "dimension",
							"$value": "{semantic.grid.margin.topLgPx}"
						},
						"bottom": {
							"$type": "dimension",
							"$value": "{semantic.grid.margin.bottomLgPx}"
						}
					}
				}
			}
		}
	}
}
