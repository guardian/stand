{
	"component": {
		"favicon": {
			"color": {
				"background": {
					"$type": "color",
					"$value": "{base.colors.cyan.200}"
				},
				"text": {
					"$type": "color",
					"$value": "{semantic.colors.text.strongerInverse}"
				}
			},
			"size": {
				"$type": "dimension",
				"$value": "{base.sizing.size32Rem}"
			},
			"display": {
				"$type": "string",
				"$value": "inline-flex"
			},
			"alignItems": {
				"$type": "string",
				"$value": "center"
			},
			"justifyContent": {
				"$type": "string",
				"$value": "center"
			},
			"userSelect": {
				"$type": "string",
				"$value": "none"
			},
			"typography": {
				"font": {
					"$type": "typography",
					"$value": "{semantic.typography.titleMd.font}"
				},
				"letterSpacing": {
					"$type": "dimension",
					"$value": "{semantic.typography.titleMd.letterSpacing}"
				},
				"fontWidth": {
					"$type": "number",
					"$value": "{semantic.typography.titleMd.fontWidth}"
				}
			}
		}
	}
