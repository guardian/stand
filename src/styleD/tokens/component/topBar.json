{
	"component": {
		"TopBar": {
			"background-color": {
				"$type": "color",
				"$value": "{semantic.colors.bg.raised-level-1}"
			},
			"display": {
				"$type": "string",
				"$value": "flex"
			},
			"height": {
				"$type": "dimension",
				"$value": "{base.spacing.64-rem}"
			},
			"justify-content": {
				"$type": "string",
				"$value": "flex-start"
			},
			"border-right": {
				"$type": "border",
				"$value": {
					"color": "{semantic.colors.border.weak}",
					"width": "{semantic.sizing.border.default}",
					"style": "solid"
				}
			},
			"border-top": {
				"$type": "border",
				"$value": {
					"color": "{semantic.colors.border.weak}",
					"width": "{semantic.sizing.border.default}",
					"style": "solid"
				}
			},
			"border-bottom": {
				"$type": "border",
				"$value": {
					"color": "{semantic.colors.border.weak}",
					"width": "{semantic.sizing.border.default}",
					"style": "solid"
				}
			},
			"border-left": {
				"$type": "border",
				"$value": {
					"color": "{semantic.colors.border.weak}",
					"width": "{semantic.sizing.border.default}",
					"style": "solid"
				}
			},
			"spacer": {
				"margin-left": {
					"$type": "string",
					"$value": "auto"
				}
			},
			"collapsedNavMenu": {
				"button": {
					"color": {
						"$type": "color",
						"$value": "{semantic.colors.text.strong}"
					},
					"margin": {
						"$type": "dimension",
						"$value": "0"
					},
					"padding": {
						"$type": "dimension",
						"$value": "0"
					},
					"background": {
						"$type": "color",
						"$value": "none"
					},
					"border": {
						"$type": "border",
						"$value": "none"
					},
					"cursor": {
						"$type": "string",
						"$value": "pointer"
					},
					"hovered": {
						"background-color": {
							"$type": "color",
							"$value": "{semantic.colors.bg.raised-level-2}"
						}
					},
					"active": {
						"background-color": {
							"$type": "color",
							"$value": "{semantic.colors.bg.raised-level-2}"
						}
					}
				},
				"popover": {
					"background-color": {
						"$type": "color",
						"$value": "{semantic.colors.bg.raised-level-1}"
					},
					"border": {
						"$type": "border",
						"$value": {
							"color": "{semantic.colors.border.weak}",
							"width": "{semantic.sizing.border.default}",
							"style": "solid"
						}
					},
					"offset": {
						"$description": "The additional offset applied along the main axis between the element and its anchor element. https://react-aria.adobe.com/Popover#popover",
						"$type": "number",
						"$value": 1
					},
					"containerPadding": {
						"$description": "The placement padding that should be applied between the element and its surrounding container. https://react-aria.adobe.com/Popover#popover",
						"$type": "number",
						"$value": 0
					}
				}
			}
		}
	}
}
